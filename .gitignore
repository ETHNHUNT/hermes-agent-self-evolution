__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
.env
.DS_Store

# Generated eval datasets — ignore by default
datasets/**/*.jsonl
datasets/**/*.json
# But allow curated/committed eval datasets
!datasets/tools/devtools_v1.jsonl
!datasets/tools/combined_eval.jsonl
!datasets/prompts/*_eval.jsonl

# Evolution output (generated at runtime, not committed)
output/
datasets_output/
snapshots/
*.pkl

# Autoresearch results (generated at runtime)
autoresearch/**/results.json

# IDE
.idea/
.vscode/
*.swp
*.swo
